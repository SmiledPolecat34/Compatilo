# Base de données PostgreSQL
DATABASE_URL="postgresql://compatilo:compatilo_dev@localhost:5432/compatilo"

# Secrets (générer des valeurs aléatoires longues en production)
JWT_SECRET="change-me-64-random-chars"
PIN_PEPPER="change-me-another-64-random-chars"

# Compte administrateur initial (créé par le seed)
ADMIN_EMAIL="jordanprime40@gmail.com"
ADMIN_PASSWORD="change-me-strong-password"

# URL du frontend (CORS + liens d'invitation)
WEB_ORIGIN="http://localhost:5173"

PORT=4000
NODE_ENV=development

# 2FA
TOTP_ISSUER="Compatilo"
TRUSTED_DEVICE_DAYS=30

# Envoi d'e-mail pour le code OTP. Sans SMTP_HOST, le code est journalisé
# dans les logs du serveur (pratique en développement).
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Compatilo <no-reply@compatilo.app>"

# Musique — stockage des fichiers uploadés (voir README pour la production)
MUSIC_UPLOAD_DIR="uploads/audio"
MUSIC_MAX_FILE_MB=25
