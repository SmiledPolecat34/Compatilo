// Compatilo — schéma de données
// PostgreSQL + Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────── Admin ───────────────────────────────
// 2FA : méthode par défaut = code envoyé par e-mail (fonctionne sans
// configuration préalable). L'admin peut ensuite activer le TOTP
// (Google Authenticator, Authy...) qui devient alors la méthode active.
// Les deux méthodes partagent le même compteur de tentatives / verrouillage.

enum TwoFactorMethod {
  EMAIL_OTP
  TOTP
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  twoFactorMethod    TwoFactorMethod @default(EMAIL_OTP)
  totpSecret         String? // secret base32, actif seulement si totpEnabled
  totpEnabled        Boolean         @default(false)
  otpCodeHash        String? // code OTP en attente (e-mail), hashé
  otpExpiresAt       DateTime?
  otpAttempts        Int             @default(0)
  otpLockedUntil     DateTime?

  // Incrémenté pour révoquer d'un coup tous les jetons déjà émis
  // ("déconnexion de tous les appareils") — chaque JWT embarque la valeur
  // en vigueur au moment de sa signature et est rejeté si elle diverge.
  tokenVersion Int @default(0)

  trustedDevices TrustedDevice[]
}

// Permet de sauter le 2FA pendant une durée configurable (TRUSTED_DEVICE_DAYS).
model TrustedDevice {
  id         String   @id @default(cuid())
  adminId    String
  admin      Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique // sha256 du jeton stocké dans le cookie
  label      String? // ex. dérivé du user-agent
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())

  @@index([adminId])
}

// ──────────────────────────── Questionnaire ──────────────────────────
// Un questionnaire possède des versions. Seule une version DRAFT est
// éditable ; publier fige la version. Les sessions pointent vers une
// version publiée, ce qui garantit l'immutabilité des rapports.

enum VersionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Questionnaire {
  id          String                 @id @default(cuid())
  title       String
  description String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  versions    QuestionnaireVersion[]
}

model QuestionnaireVersion {
  id              String        @id @default(cuid())
  questionnaireId String
  questionnaire   Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  version         Int
  status          VersionStatus @default(DRAFT)
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  pages           Page[]
  sessions        Session[]

  @@unique([questionnaireId, version])
}

model Page {
  id          String               @id @default(cuid())
  versionId   String
  version     QuestionnaireVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  title       String
  description String?
  position    Int
  isActive    Boolean              @default(true)
  questions   Question[]

  @@index([versionId, position])
}

// `type` + `config` (JSON) rendent l'ajout de nouveaux types de questions
// possible sans migration : le rendu est piloté par un registre côté front.
model Question {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type      String   @default("trilean") // trilean = Oui / Possible / Non
  prompt    String
  helpText  String?
  position  Int
  isActive  Boolean  @default(true)
  required  Boolean  @default(true)
  config    Json     @default("{}")
  answers   Answer[]

  @@index([pageId, position])
}

// ─────────────────────────────── Session ─────────────────────────────

// 🟢 ACTIVE (ouverte) → 🟡 COMPLETED (en attente, rapport généré) → 🔴 CLOSED
// (fermée, verrouillée définitivement par l'admin) ; ARCHIVED = masquée.
// CLOSED gèle toute écriture (réponses, favoris, signatures, nouveaux
// participants) indépendamment de `reportAccessEnabled`, qui ne gouverne
// que la lecture du rapport.
enum SessionStatus {
  ACTIVE
  COMPLETED
  CLOSED
  ARCHIVED
}

// Ce que l'invité voit du nom d'un participant (l'admin voit toujours tout).
enum IdentityDisplay {
  FIRST_NAME
  NICKNAME
  BOTH
  NONE // réservé : anonymisation complète ("Participant 1/2")
}

model Session {
  id                  String               @id @default(cuid())
  publicId            String               @unique // identifiant non prévisible (nanoid)
  label               String?
  pinHash             String // bcrypt
  pinLookup           String               @unique // HMAC-SHA256(pin, pepper) pour retrouver la session
  status              SessionStatus        @default(ACTIVE)
  versionId           String
  version             QuestionnaireVersion @relation(fields: [versionId], references: [id])
  expiresAt           DateTime?
  reportAccessEnabled Boolean              @default(true)
  identityDisplay     IdentityDisplay      @default(BOTH)
  playlistId          String?
  playlist            Playlist?            @relation(fields: [playlistId], references: [id], onDelete: SetNull)
  closedAt            DateTime?
  privateNotes        String?
  failedAttempts      Int                  @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  participants        Participant[]
  timeline            TimelineEvent[]
  report              Report?
}

model Participant {
  id              String      @id @default(cuid())
  sessionId       String
  session         Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  slot            Int // 1 ou 2
  firstName       String
  nickname        String?
  snapchat        String?
  instagram       String?
  phone           String?
  birthDate       DateTime?
  origins         Json?
  locationConsent Boolean     @default(false)
  city            String?
  latitude        Float? // visibles uniquement par l'admin
  longitude       Float?
  joinedAt        DateTime    @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  answers         Answer[]
  favorites       Favorite[]
  signatures      Signature[]

  @@unique([sessionId, slot])
}

model Answer {
  id            String      @id @default(cuid())
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  questionId    String
  question      Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  value         Json
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([participantId, questionId])
}

model Favorite {
  id            String      @id @default(cuid())
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  questionId    String
  createdAt     DateTime    @default(now())

  @@unique([participantId, questionId])
}

// ─────────────────────────────── Rapport ─────────────────────────────
// `data` est un instantané complet (questions, réponses, comparaisons,
// favoris, score) : le rapport reste stable même si le questionnaire évolue.

model Report {
  id          String      @id @default(cuid())
  sessionId   String      @unique
  session     Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  code        String      @unique // identité unique, ex. CMP-7F3K-92QX
  score       Int
  data        Json
  generatedAt DateTime    @default(now())
  signatures  Signature[]
}

model Signature {
  id            String      @id @default(cuid())
  reportId      String
  report        Report      @relation(fields: [reportId], references: [id], onDelete: Cascade)
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  image         String // data URL PNG
  signedAt      DateTime    @default(now())

  @@unique([reportId, participantId])
}

// ─────────────────────────────── Musique ──────────────────────────────
// Module indépendant du reste de l'application (Provider pattern) :
// aujourd'hui LOCAL (fichiers hébergés) et YOUTUBE (métadonnées oEmbed +
// lecture via le lecteur officiel YouTube). Ajouter Spotify/Deezer/etc.
// plus tard = un nouveau TrackType + un provider front, sans migration
// de structure ni changement des autres modules.

enum TrackType {
  LOCAL
  YOUTUBE
}

model Playlist {
  id        String          @id @default(cuid())
  name      String
  isDefault Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  tracks    PlaylistTrack[]
  sessions  Session[]
}

model Track {
  id              String          @id @default(cuid())
  type            TrackType
  title           String
  artist          String?
  durationSeconds Int?
  fileKey         String? // LOCAL : chemin relatif dans le stockage
  youtubeVideoId  String? // YOUTUBE
  thumbnailUrl    String?
  createdAt       DateTime        @default(now())
  playlists       PlaylistTrack[]
}

model PlaylistTrack {
  id         String   @id @default(cuid())
  playlistId String
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  trackId    String
  track      Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  position   Int

  @@unique([playlistId, trackId])
  @@index([playlistId, position])
}

// Réglages globaux (ligne unique, id fixe "singleton").
model MusicSettings {
  id                String  @id @default("singleton")
  enabled           Boolean @default(true)
  defaultPlaylistId String?
}

// ─────────────────────────────── Timeline ────────────────────────────

model TimelineEvent {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type      String // session.created, pin.generated, participant.joined, ...
  message   String
  meta      Json?
  createdAt DateTime @default(now())

  @@index([sessionId, createdAt])
}
